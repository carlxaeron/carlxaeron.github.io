# Namecheap API — copy to .env and fill values.
# Dashboard: https://ap.www.namecheap.com/settings/tools/apiaccess/
#
# 1. Enable API Access
# 2. Whitelist your public IP (current known: 165.101.154.162)
# 3. Create / copy API key
# 4. Restart Cursor MCP after saving .env

NAMECHEAP_API_USER=your_namecheap_username
NAMECHEAP_USERNAME=your_namecheap_username
NAMECHEAP_API_KEY=your_api_key_here
NAMECHEAP_CLIENT_IP=165.101.154.162

# Optional: set true to use Namecheap sandbox (no real charges)
# NAMECHEAP_SANDBOX=false
