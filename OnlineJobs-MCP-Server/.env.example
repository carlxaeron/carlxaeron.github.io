# Apify API token — https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_YOUR_TOKEN_HERE

# Local dashboard port (default 8787)
# DASHBOARD_PORT=8787

# --- CV cloud upload (optional) ---
# Provider: dropbox | google_drive
# CV_UPLOAD_PROVIDER=dropbox

# Dropbox — https://www.dropbox.com/developers/apps (scoped app, files.content.write + sharing.write)
# DROPBOX_ACCESS_TOKEN=sl.u.YOUR_TOKEN
# DROPBOX_CV_FOLDER=/job-applications

# Google Drive — run: uv run python scripts/google_drive_auth.py
# CV_UPLOAD_PROVIDER=google_drive
# GOOGLE_DRIVE_CLIENT_ID=
# GOOGLE_DRIVE_CLIENT_SECRET=
# GOOGLE_DRIVE_REFRESH_TOKEN=
# GOOGLE_DRIVE_FOLDER_ID=
