# Namecheap dashboard login (browser automation via Chrome DevTools MCP).
# Copy to `.namecheap-browser.env` (gitignored) and fill values.
# Never commit the filled file. Prefer App Password / 2FA when available.

# Namecheap account (https://www.namecheap.com/myaccount/login/)
NAMECHEAP_USERNAME=
NAMECHEAP_PASSWORD=

# Optional: if 2FA is on, leave blank — agent will pause for you to complete 2FA in the browser tab.
# NAMECHEAP_2FA_HINT=authenticator

# Private Email webmail (https://privateemail.com/) — only if different from Namecheap login
# PRIVATEEMAIL_USERNAME=sales@carlmanuel.com
# PRIVATEEMAIL_PASSWORD=
