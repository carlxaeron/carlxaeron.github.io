# Namecheap Stellar shared hosting (tahanan.org)
SSH_HOST=server402.web-hosting.com
SSH_PORT=21098
SSH_USERNAME=carlxaeron
# Prefer key auth (path relative to this folder or absolute)
SSH_PRIVATE_KEY_PATH=.ssh/tahanan_mcp
# Optional password fallback (leave empty when using key)
SSH_PASSWORD=
# Jail file ops under this remote prefix (default: home)
SSH_HOME=/home/carlxaeron
# Max bytes returned by hosting_read / hosting_exec stdout
SSH_MAX_READ_BYTES=524288
SSH_EXEC_TIMEOUT_MS=60000
