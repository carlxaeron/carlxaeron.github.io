# Copy to firestore-send-email.env and fill in before:
#   firebase ext:install firebase/firestore-send-email --project=carllouismanuel-1e3a9
# Or install via Firebase Console → Extensions → Trigger Email from Firestore

MAIL_COLLECTION=mail
DEFAULT_FROM=info@carlmanuel.com
DEFAULT_REPLY_TO=info@carlmanuel.com

# Gmail (current setup): use App Password (not your login password)
# 1. Google Account → Security → 2-Step Verification → App passwords
# 2. Create password for "Mail", 16 characters without spaces in URI:
# SMTP_CONNECTION_URI=smtps://carllouismanuel09@gmail.com:YOUR_16_CHAR_APP_PASSWORD@smtp.gmail.com:465
# DEFAULT_FROM=carllouismanuel09@gmail.com
#
# SendGrid alternative:
# SMTP_CONNECTION_URI=smtps://apikey@sendgrid.net:465
# SMTP_PASSWORD=<your SendGrid API key>

# Gmail OAuth2: see https://firebase.google.com/docs/extensions/official/firestore-send-email
