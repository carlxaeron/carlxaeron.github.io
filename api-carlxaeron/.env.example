APP_NAME="api-carlxaeron"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://api.carlmanuel.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MySQL (Laravel names). Legacy DB_NAME / DB_USER / DB_PASS also work via config fallbacks.
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=carlxaeron_api
DB_USERNAME=carlxaeron_api
DB_PASSWORD=
# DB_NAME=
# DB_USER=
# DB_PASS=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=smtp
# Namecheap Private Email (https://privateemail.com)
MAIL_HOST=mail.privateemail.com
MAIL_PORT=465
MAIL_USERNAME=info@carlmanuel.com
MAIL_PASSWORD=
MAIL_SCHEME=smtps
MAIL_FROM_ADDRESS=info@carlmanuel.com
MAIL_FROM_NAME="Carl Manuel Portfolio"
# Legacy PHP hosting keys (still used until Laravel is deployed on Stellar):
# SMTP_HOST=mail.privateemail.com
# SMTP_PORT=465
# SMTP_USER=info@carlmanuel.com
# SMTP_PASS=
# SMTP_ENCRYPTION=ssl
# DEFAULT_FROM=info@carlmanuel.com

MAIL_TO=info@carlmanuel.com

# Hosting cron auto follow-ups (POST /outreachSchedule). Keep secret out of git.
OUTREACH_SECRET=

ANALYTICS_EXCLUDE_IP_HASHES=
ANALYTICS_EXCLUDE_VISITOR_IDS=
CLIENT_SITES_COUNT=11

# Admin dashboard (Sanctum). Set on server only — never commit real password.
ADMIN_EMAIL=info@carlmanuel.com
ADMIN_PASSWORD=
