# Copy to .env on the server (never commit real secrets)
DB_HOST=localhost
DB_NAME=carlxaeron_api
DB_USER=carlxaeron_api
DB_PASS=

SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=info@carlmanuel.com
SMTP_PASS=
SMTP_ENCRYPTION=ssl
DEFAULT_FROM=info@carlmanuel.com
MAIL_TO=info@carlmanuel.com
# BCC on outbound client outreach (hidden from To recipient)
MAIL_BCC=info@carlmanuel.com

OUTREACH_SECRET=
# Optional: same as Laravel PREVIEW_ACCESS_SECRET when hosting-php calls redeem (not required for cron).
PREVIEW_ACCESS_SECRET=
DEFAULT_FROM_NAME=Carl Louis Manuel

# Public endpoint IP rate limits (defaults shown). Fail-open if storage unwritable.
RATE_LIMIT_CONTACT=8
RATE_LIMIT_QUOTATION=8
RATE_LIMIT_TRACK_VISIT=120
RATE_LIMIT_PREVIEW_FEEDBACK=30
RATE_LIMIT_ANALYTICS_SUMMARY=60
RATE_LIMIT_OUTREACH=60
RATE_LIMIT_ASSISTANT=30

# Portfolio ChatAgent (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Weekly visit report recipients (comma-separated)
WEEKLY_REPORT_TO=info@carlmanuel.com,carllouismanuel09@gmail.com
# Optional dedicated key for HTTP cron triggers (falls back to OUTREACH_SECRET)
CRON_SECRET=

ANALYTICS_EXCLUDE_IP_HASHES=
ANALYTICS_EXCLUDE_VISITOR_IDS=
CLIENT_SITES_COUNT=11
